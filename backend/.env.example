# --- MISSION CRITICAL CONFIGURATION ---
PORT=8080
MISSION_KEY=your_secret_tactical_key_here
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174,http://localhost:5173,http://localhost:5174,https://your-deployed-dashboard.vercel.app,http://localhost:8081,http://127.0.0.1:8081

# --- DATABASE PERSISTENCE ---
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?appName=iron-sight
DB_NAME=iron_sight
COLLECTION_NAME=salvo_history

# --- UPSTREAM RELAY (ISRAEL) ---
# GET /alerts with x-relay-auth header. Unset RELAY_URL — engine sleeps only; no live ingest.
RELAY_URL=http://<relay-host>:3001/alerts
RELAY_AUTH_KEY=your_relay_secret_here

# --- TELEGRAM (your city alerts) ---
# Bot sends a zoom-12 map PNG when an active alert includes your city.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- WEB PUSH (VAPID) ---
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_CLAIMS_EMAIL=mailto:ops@your-domain.com
