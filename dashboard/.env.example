# --- MISSION NETWORKING ---
# Production WebSocket host (optional). Default: iron-sight-hjwf.onrender.com (not the Vercel domain).
# REST stays on the Vercel origin via /api rewrite. Dev uses Vite proxy — do not set VITE_WS_URL locally.
# VITE_WS_URL=iron-sight-hjwf.onrender.com
VITE_MISSION_KEY=your_secret_tactical_key_here

# --- WEB PUSH ---
# Must match backend VAPID_PUBLIC_KEY. Generate pair: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# --- SEO (canonical, OG, sitemap) ---
# Production default: https://iron-sight-drab.vercel.app
VITE_SITE_URL=https://iron-sight-drab.vercel.app
