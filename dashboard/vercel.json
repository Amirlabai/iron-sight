{
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://iron-sight-hjwf.onrender.com/api/:path*" },
    { "source": "/ws", "destination": "https://iron-sight-hjwf.onrender.com/ws" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ]
}
